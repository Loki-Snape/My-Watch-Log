<%- include("partials/header.ejs") %>

<div class="form-container">
    <h2>Edit Movie Entry</h2>
    
    <form action="/edit/<%= m.id %>" method="POST">
    <% if(locals.m){ %>    
        <input type="hidden" name="id" value="<%= m.id %>">
            <div class="form-group">
                <label for="title">Movie Title:</label>
                <input type="text" id="title" name="title" value="<%= m.title %>" required>
            </div>

            <div class="form-group">
                <label for="watch_date">Date Watched:</label>
                <input type="date" id="watch_date" name="watch_date" value="<%= m.watch_date %>" required>
            </div>

            <div class="form-group">
                <label for="rating">Rating (1 to 5):</label>
                <input type="number" id="rating" name="rating" min="1" max="5" value="<%= m.rating %>" required>
            </div>

            <div class="form-group">
                <label for="notes">Your Notes/Review:</label>
                <textarea id="notes" name="notes" rows="4"><%= m.review %></textarea>
            </div>

            <div class="form-group">
                <label for="password">Admin Password:</label>
                <input type="password" id="password" name="password" required>
            </div>

        <button type="submit" class="button">Update Entry</button>

    <% } else { %>
        <div>
            <h1>NOTHING TO EDIT</h1>
        </div>
    <% } %>
    </form>
</div>

<%- include("partials/footer.ejs") %>