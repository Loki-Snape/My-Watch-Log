<%- include("partials/header.ejs") %>

<div class="form-container">
    <h2>Log a New Movie</h2>
    
    <form action="/add" method="POST">
        <div class="form-group">
            <label for="title">Movie Title:</label>
            <input type="text" id="title" name="title" required>
        </div>

        <div class="form-group">
            <label for="watch_date">Date Watched:</label>
            <input type="date" id="watch_date" name="watch_date" required>
        </div>

        <div class="form-group">
            <label for="rating">Rating (1 to 5):</label>
            <input type="number" id="rating" name="rating" min="1" max="5" required>
        </div>

        <div class="form-group">
            <label for="notes">Your Notes/Review:</label>
            <textarea id="notes" name="notes" rows="4"></textarea>
        </div>

        <div class="form-group">
            <label for="password">Admin Password:</label>
            <input type="password" id="password" name="password" required>
        </div>

        <button type="submit" class="button">Save to Log</button>
    </form>
</div>

<%- include("partials/footer.ejs") %>